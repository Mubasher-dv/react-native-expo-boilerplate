{
  "name": "react-native-expo-boilerplate",
  "version": "1.1.1",
  "description": "Opinionated Expo app scaffolder mirroring MyRoster conventions.",
  "type": "module",
  "bin": {
    "react-native-expo-boilerplate": "bin/cli.js"
  },
  "files": [
    "bin/",
    "dist/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "audit:templates": "bash scripts/audit-templates.sh",
    "prepublishOnly": "npm run build && npm run test && npm run audit:templates"
  },
  "keywords": [
    "expo",
    "scaffolder",
    "create-expo-app",
    "react-native"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mubasher-dv/react-native-expo-boilerplate.git"
  },
  "homepage": "https://github.com/Mubasher-dv/react-native-expo-boilerplate#readme",
  "bugs": {
    "url": "https://github.com/Mubasher-dv/react-native-expo-boilerplate/issues"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/generator": "~7.29.1",
    "@babel/parser": "~7.29.3",
    "@babel/traverse": "~7.29.0",
    "@babel/types": "~7.29.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2",
    "tar": "^7.5.15"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.2",
    "@types/prompts": "^2.4.9",
    "@types/tar": "^6.1.13",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "5.5.4",
    "vitest": "^4.1.5"
  }
}
